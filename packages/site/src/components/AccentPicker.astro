---
import { ACCENTS } from '../lib/accents';
---

<div class="relative" data-accent-picker>
  <button
    type="button"
    aria-label="Accent"
    class="inline-flex h-9 w-9 items-center justify-center rounded-lg border border-line bg-card hover:bg-bg-2 transition-colors"
    data-accent-toggle
  >
    <span
      class="h-3.5 w-3.5 rounded-full"
      data-accent-dot
      style="background: var(--brand); box-shadow: 0 0 0 1.5px var(--bg-panel), 0 0 0 2.5px color-mix(in srgb, var(--brand) 25%, transparent);"
    ></span>
  </button>

  <div
    class="absolute right-0 top-[calc(100%+6px)] z-40 hidden rounded-[10px] bg-card p-2 border border-line"
    style="box-shadow: var(--shadow-elevated);"
    data-accent-menu
  >
    <div class="flex flex-col gap-1">
      {
        ACCENTS.map((a) => (
          <button
            type="button"
            class="flex items-center gap-2.5 rounded-md px-2.5 py-1.5 text-left text-xs font-medium text-ink-2 hover:bg-bg-2 hover:text-ink whitespace-nowrap"
            data-accent-option={a.id}
          >
            <span class="h-3 w-3 flex-shrink-0 rounded-full" style={`background: ${a.dot};`}></span>
            <span>{a.name}</span>
          </button>
        ))
      }
    </div>
  </div>
</div>
