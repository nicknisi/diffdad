---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import StoryExample from '../components/StoryExample.astro';
import Install from '../components/Install.astro';
import Usage from '../components/Usage.astro';
import Features from '../components/Features.astro';
import ProvidersAndAuth from '../components/ProvidersAndAuth.astro';
import Shortcuts from '../components/Shortcuts.astro';
import CTAStrip from '../components/CTAStrip.astro';
import Footer from '../components/Footer.astro';
import { renderDadMarkSVG, ACCENT_BG } from '../lib/dad-mark';
import { DEFAULT_ACCENT } from '../lib/accents';

const defaultFavicon = `data:image/svg+xml,${encodeURIComponent(
  renderDadMarkSVG({ size: 32, bg: ACCENT_BG[DEFAULT_ACCENT], shape: 'circle', showBadge: false }),
)}`;

// Resolve absolute URLs against the actual host (dev: localhost; preview/prod: the
// deploy URL via CF_PAGES_URL) so social-preview tools that don't follow relative
// paths still find the asset.
const baseUrl = Astro.url;
const ogImage = new URL('/og.png', baseUrl).href;
const twitterImage = new URL('/twitter.png', baseUrl).href;
---

<html lang="en" data-accent="dadcore">
  <head>
    <meta charset="utf-8" />
    <title>diff.dad — your PRs, told as a story</title>
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta
      name="description"
      content="Turn GitHub PRs into narrated stories. dad reads the whole pull request, groups changes by behavior into chapters, and walks you through them with prose, risk levels, and inline comments."
    />
    <link rel="canonical" href="https://diff.dad/" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://diff.dad/" />
    <meta property="og:title" content="diff.dad — your PRs, told as a story" />
    <meta
      property="og:description"
      content="A storytelling PR reviewer. Semantic chapters, risk levels, inline GitHub comments. brew install dad."
    />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="diff.dad — your PRs, told as a story" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="diff.dad — your PRs, told as a story" />
    <meta name="twitter:description" content="A storytelling PR reviewer. brew install dad." />
    <meta name="twitter:image" content={twitterImage} />
    <meta name="twitter:image:alt" content="diff.dad — your PRs, told as a story" />

    <link rel="icon" type="image/svg+xml" href={defaultFavicon} />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&family=Fraunces:opsz,wght@9..144,400;9..144,600;9..144,700&display=swap"
      rel="stylesheet"
    />
    <script src="https://cdn.usefathom.com/script.js" data-site="FBKWVVRO" defer is:inline></script>
    <script is:inline>
      // Pre-paint: apply stored theme + accent before render to avoid FOUC.
      (() => {
        const root = document.documentElement;
        const t = localStorage.getItem('diffdad.theme') || 'auto';
        const a = localStorage.getItem('diffdad.accent') || 'dadcore';
        const resolved = t === 'auto' ? (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light') : t;
        if (resolved === 'dark') root.classList.add('dark');
        if (a && a !== 'classic') root.setAttribute('data-accent', a);
        else root.removeAttribute('data-accent');
      })();
    </script>
  </head>
  <body>
    <div class="wrap"><Nav /></div>
    <div class="wrap"><Hero /></div>
    <StoryExample />
    <Install />
    <Usage />
    <Features />
    <ProvidersAndAuth />
    <Shortcuts />
    <CTAStrip />
    <Footer />
  </body>
</html>
